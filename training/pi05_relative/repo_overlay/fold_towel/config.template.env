# Required project values. Leave blank until the fold_towel dataset and output paths are decided.
DATASET_REPO_ID=bryce301best/fold_towel_ee
DATASET_ROOT=/public/home/chenglongyan/workspace/lerobot/hf_downloads/datasets/fold_towel_fixed_base_ee14
OUTPUT_DIR=/public/home/chenglongyan/workspace/lerobot/outputs/train/pi05_fold_towel_fixed_base_ee14_8gpu
JOB_NAME=pi05_fold_towel_fixed_base_ee14_8gpu

# PI0.5 base model. Current training used the local cache below.
POLICY_PRETRAINED_PATH=hf_downloads/models/pi05_base

# Current PI0.5 relative-action training defaults.
POLICY_TYPE=pi05
USE_RELATIVE_ACTIONS=true
RELATIVE_ACTION_TYPE=ee_so3
RELATIVE_EXCLUDE_JOINTS='["gripper"]'
DTYPE=bfloat16
GRADIENT_CHECKPOINTING=true
COMPILE_MODEL=false
FREEZE_VISION_ENCODER=false
TRAIN_EXPERT_ONLY=false
CHUNK_SIZE=50
N_ACTION_STEPS=50

# Training schedule and dataloader.
BATCH_SIZE=32
STEPS=20000
SAVE_FREQ=2000
LOG_FREQ=1
EVAL_FREQ=20000
NUM_WORKERS=8
SEED=1000

# Logging and launch.
WANDB_ENABLE=false
DEVICE=cuda
NUM_PROCESSES=8
PUSH_TO_HUB=false
